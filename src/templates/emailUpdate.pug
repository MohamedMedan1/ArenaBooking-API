doctype html
html(lang="en")
  head
    meta(http-equiv="Content-Type", content="text/html; charset=UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title Email Updated 🛡️
    style.
      body {
        margin: 0;
        padding: 0;
        background-color: #0a0a0a;
        font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      }
      .wrapper {
        width: 100%;
        padding: 40px 0;
      }
      .main-container {
        max-width: 550px;
        background-color: #141414;
        margin: 0 auto;
        border-radius: 30px;
        overflow: hidden;
        border: 1px solid #222222;
        box-shadow: 0 20px 40px rgba(0,0,0,0.5);
      }
      .header-gradient {
        background: linear-gradient(135deg, #007bff 0%, #0056b3 100%);
        padding: 50px 20px;
        text-align: center;
      }
      .header-gradient h1 {
        margin: 0;
        color: #ffffff;
        font-size: 24px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 4px;
      }
      .content {
        padding: 40px;
        color: #ffffff;
      }
      .content h2 {
        margin: 0 0 10px 0;
        font-size: 32px;
        font-weight: 700;
        letter-spacing: -1px;
      }
      .security-text {
        color: #888888;
        font-size: 16px;
        margin-bottom: 30px;
        line-height: 1.6;
      }
      .info-card {
        background: #1c1c1c;
        border: 1px solid #333333;
        border-radius: 24px;
        padding: 30px;
        margin-bottom: 30px;
      }
      .detail-item {
        margin-bottom: 20px;
      }
      .detail-item:last-child {
        margin-bottom: 0;
      }
      .detail-label {
        color: #555555;
        text-transform: uppercase;
        font-size: 10px;
        font-weight: 900;
        letter-spacing: 2px;
        margin-bottom: 4px;
      }
      .detail-value {
        color: #ffffff;
        font-size: 16px;
        font-weight: 600;
        word-break: break-all;
      }
      .old-value {
        text-decoration: line-through;
        color: #ff4d4d;
        opacity: 0.7;
      }
      .new-value {
        color: #007bff;
        text-shadow: 0 0 10px rgba(0, 123, 255, 0.2);
      }
      .divider {
        height: 1px;
        background: #333333;
        margin: 15px 0;
      }
      .footer {
        padding: 30px;
        text-align: center;
        background-color: #0f0f0f;
        border-top: 1px solid #222222;
      }
      .footer p {
        color: #444444;
        font-size: 11px;
        margin: 5px 0;
        text-transform: uppercase;
        letter-spacing: 1px;
      }

  body
    table.wrapper(width="100%", border="0", cellpadding="0", cellspacing="0")
      tr
        td(align="center")
          table.main-container(border="0", cellpadding="0", cellspacing="0")
            //- Header
            tr
              td.header-gradient
                h1 Security Alert
            
            //- Body
            tr
              td.content
                h2 Hi #{firstName},
                p.security-text We wanted to let you know that your account email address has been successfully updated.

                div.info-card
                  div.detail-item
                    div.detail-label 📧 Previous Email
                    div.detail-value.old-value #{oldEmail}
                  
                  div.divider

                  div.detail-item
                    div.detail-label 🛡️ New Primary Email
                    div.detail-value.new-value #{newEmail}

                p.security-text(style="font-size: 14px;") If you did not make this change, please contact our support team immediately to secure your account.

            //- Footer
            tr
              td.footer
                p © 2026 ArenaBooking System
                p SECURE ACCESS • HIGH PERFORMANCE RESERVATIONS