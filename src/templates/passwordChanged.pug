doctype html
html(lang="en")
  head
    meta(http-equiv="Content-Type", content="text/html; charset=UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title Password Updated 🔐
    style.
      body {
        margin: 0;
        padding: 0;
        background-color: #0a0a0a;
        font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      }
      .wrapper {
        width: 100%;
        padding: 40px 0;
      }
      .main-container {
        max-width: 500px;
        background-color: #141414;
        margin: 0 auto;
        border-radius: 30px;
        overflow: hidden;
        border: 1px solid #222222;
        box-shadow: 0 20px 40px rgba(0,0,0,0.5);
      }
      .header-gradient {
        background: linear-gradient(135deg, #d9534f 0%, #b52b27 100%);
        padding: 40px 20px;
        text-align: center;
      }
      .header-gradient h1 {
        margin: 0;
        color: #ffffff;
        font-size: 20px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 3px;
      }
      .content {
        padding: 40px;
        color: #ffffff;
      }
      .content h2 {
        margin: 0 0 10px 0;
        font-size: 28px;
        font-weight: 700;
        letter-spacing: -1px;
      }
      .alert-text {
        color: #aaaaaa;
        font-size: 15px;
        margin-bottom: 25px;
        line-height: 1.6;
      }
      .security-box {
        background: #1c1c1c;
        border-left: 4px solid #d9534f;
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 25px;
      }
      .info-row {
        margin-bottom: 5px;
        font-size: 14px;
      }
      .info-label {
        color: #555555;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-right: 8px;
      }
      .info-value {
        color: #ffffff;
        font-weight: 600;
      }
      .footer {
        padding: 25px;
        text-align: center;
        background-color: #0f0f0f;
        border-top: 1px solid #222222;
      }
      .footer p {
        color: #444444;
        font-size: 10px;
        margin: 4px 0;
        text-transform: uppercase;
        letter-spacing: 1px;
      }

  body
    table.wrapper(width="100%", border="0", cellpadding="0", cellspacing="0")
      tr
        td(align="center")
          table.main-container(border="0", cellpadding="0", cellspacing="0")
            //- Header
            tr
              td.header-gradient
                h1 Security Alert
            
            //- Body
            tr
              td.content
                h2 Hi #{firstName},
                p.alert-text This is a confirmation that your account password has been successfully changed.

                div.security-box
                  div.info-row
                    span.info-label 📅 Date:
                    span.info-value #{changeDate}
                  
                  div.info-row
                    span.info-label 🛡️ Status:
                    span.info-value Secure & Updated

                p.alert-text(style="font-size: 13px; color: #666; margin-bottom: 0;") If you did not perform this action, please contact our support team immediately.

            //- Footer
            tr
              td.footer
                p © 2026 ArenaBooking System
                p ENCRYPTED • SECURE • RELIABLE